# Gemini API Key (Get from Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# Video Settings
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920
VIDEO_FPS=24
VIDEO_DURATION=30

# Schedule Settings (24h format)
SCHEDULE_TIME_1=08:00
SCHEDULE_TIME_2=20:00

# TTS Settings
TTS_LANGUAGE=ko
TTS_VOICE=ko-KR-SunHiNeural
